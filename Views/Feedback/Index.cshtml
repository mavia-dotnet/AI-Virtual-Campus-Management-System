@model IEnumerable<Ai_Virtual_Campus_Management_System.Models.Feedback>

<div class="container mt-4">

    <h2>Student Feedback</h2>

    <a asp-action="Create" class="btn btn-success mb-3">
        Add Feedback
    </a>

    <table class="table table-bordered">

        <thead>
            <tr>
                <th>ID</th>
                <th>Student Name</th>
                <th>Message</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.StudentName</td>
                    <td>@item.Message</td>
                </tr>
            }

        </tbody>

    </table>

</div>
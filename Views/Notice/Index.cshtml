@model IEnumerable<Ai_Virtual_Campus_Management_System.Models.Notice>

<div class="container mt-4">

    <h2>Notices</h2>

    <a asp-action="Create" class="btn btn-success mb-3">
        Add Notice
    </a>

    <table class="table table-bordered">

        <thead>
            <tr>
                <th>ID</th>
                <th>Title</th>
                <th>Description</th>
                <th>Date</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.Title</td>
                    <td>@item.Description</td>
                    <td>@item.Date</td>
                </tr>
            }

        </tbody>

    </table>

</div>